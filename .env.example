# GMGN OpenAPI — read-only key from gmgn.ai/ai
# X-APIKEY header value, no signing required for read endpoints
GMGN_API_KEY=

# Bitquery EAP — Developer plan token from bitquery.io
BITQUERY_TOKEN=

# Helius — free tier from helius.dev (used for CEX/protocol entity labels)
# Optional: if unset, funder labels will be unknown and funding source falls
# back to v1 heuristic.
HELIUS_API_KEY=

# Supabase — from project settings > API
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: deployment URL for share links (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
